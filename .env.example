# ─────────────────────────────────────────────────────────────────────────────
# Auto-Living Docs — Environment Variables
#
# For local dev:  copy to .dev.vars (Wrangler reads this automatically)
# For production: wrangler secret put VAR_NAME  (never commit real values)
# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub App ────────────────────────────────────────────────────────────────
# From: github.com/settings/apps/YOUR_APP → App ID shown at the top
GITHUB_APP_ID=123456

# From: github.com/settings/apps/YOUR_APP → Private keys → Generate
# Convert to base64: cat private-key.pem | base64 | tr -d '\n'
GITHUB_APP_PRIVATE_KEY=base64encodedpemhere

# Any strong random string — set EXACTLY this value in GitHub App webhook settings
# Generate: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# ── GitHub OAuth App ──────────────────────────────────────────────────────────
# From: github.com/settings/developers → OAuth Apps → New OAuth App
# Homepage URL: http://localhost:8787  (dev) or your prod URL
# Callback URL: http://localhost:8787/auth/callback
GITHUB_OAUTH_CLIENT_ID=Iv1.your_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_client_secret

# ── LLM ──────────────────────────────────────────────────────────────────────
# From: console.anthropic.com/api-keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Database (Week 2) ─────────────────────────────────────────────────────────
# From: app.planetscale.com → Connect → @planetscale/database
DATABASE_URL=mysql://user:password@host/database?ssl={"rejectUnauthorized":true}

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:8787
